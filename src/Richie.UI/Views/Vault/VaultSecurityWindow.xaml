<ui:FluentWindow x:Class="Richie.UI.Views.Vault.VaultSecurityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Vault security"
        Height="640" Width="480"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vault security" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
            <StackPanel>
                <!-- Change master password -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Change master password" Margin="0,0,0,8" />
                        <ui:PasswordBox PlaceholderText="Current master password" Margin="0,0,0,8"
                                        Password="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:PasswordBox PlaceholderText="New master password (min 8 chars)" Margin="0,0,0,8"
                                        Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:PasswordBox PlaceholderText="Confirm new master password" Margin="0,0,0,8"
                                        Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button Content="Change password" Appearance="Primary" Command="{Binding ChangePasswordCommand}" />
                        <ui:TextBlock TextWrapping="Wrap" Margin="0,8,0,0" Text="{Binding ChangeMessage}" />
                    </StackPanel>
                </ui:Card>

                <!-- Security-question recovery -->
                <ui:Card>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Forgot-password recovery" />
                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,4,0,8"
                                      Text="Answer your security questions to enable unlocking the vault if you forget the master password." />
                        <ui:InfoBar Severity="Success" IsOpen="{Binding RecoveryEnabled}" IsClosable="False" Margin="0,0,0,8"
                                    Message="Security-question recovery is enabled." />

                        <ItemsControl ItemsSource="{Binding Answers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Text="{Binding QuestionText}" />
                                        <ui:TextBox Margin="0,2,0,0"
                                                    Text="{Binding Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="Enable recovery" Command="{Binding EnableRecoveryCommand}" Margin="0,4,0,0" />
                        <ui:TextBlock TextWrapping="Wrap" Margin="0,8,0,0" Text="{Binding RecoveryMessage}" />
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
