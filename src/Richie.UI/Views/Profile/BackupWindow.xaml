<ui:FluentWindow x:Class="Richie.UI.Views.Profile.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Backup &amp; Restore"
        Height="420" Width="520"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Backup &amp; Restore" />

        <StackPanel Grid.Row="1" Margin="24,8,24,16">
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Backup" Margin="0,0,0,4" />
                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,0,0,8"
                                  Text="Saves an encrypted archive of your database and document/photo/receipt files. The archive is unreadable without this app on this Windows account." />
                    <ui:TextBlock x:Name="LastBackupText" Appearance="Secondary" FontTypography="Caption" Margin="0,0,0,8" />
                    <ui:Button Content="Back up now…" Appearance="Primary" Click="OnBackup" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <ui:Card>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Restore" Margin="0,0,0,4" />
                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,0,0,8"
                                  Text="Restores from a backup archive created on this machine. This overwrites your current data — restart the app afterward." />
                    <ui:Button Content="Restore from backup…" Click="OnRestore" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
