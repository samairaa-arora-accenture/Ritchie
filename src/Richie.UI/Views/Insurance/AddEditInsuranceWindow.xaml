<ui:FluentWindow x:Class="Richie.UI.Views.Insurance.AddEditInsuranceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Insurance policy"
        Height="640" Width="460"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding Title}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,8">
            <StackPanel>
                <ui:TextBlock Text="Type" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Types}" DisplayMemberPath="Text" SelectedValuePath="Value"
                          SelectedValue="{Binding Type}" Margin="0,0,0,10" />

                <ui:TextBox PlaceholderText="Policy name" Margin="0,0,0,10"
                            Text="{Binding PolicyName, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Policy number" Margin="0,0,0,10"
                            Text="{Binding PolicyNumber, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Provider" Margin="0,0,0,10"
                            Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Coverage amount" Margin="0,0,0,10"
                            Text="{Binding CoverageAmount, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Annual premium" Margin="0,0,0,10"
                            Text="{Binding AnnualPremium, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBlock Text="Start date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,0,10" />
                <ui:TextBlock Text="Renewal date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding RenewalDate}" Margin="0,0,0,10" />

                <ui:TextBox PlaceholderText="Nominee" Margin="0,0,0,10"
                            Text="{Binding Nominee, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Notes" Margin="0,0,0,10" AcceptsReturn="True" MinLines="2"
                            Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap" Text="{Binding Error}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <ui:Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <ui:Button Content="Save" Appearance="Primary" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
