        <ui:Button Content="Replay app tour" Click="OnReplayTour" />
        <ui:TextBlock Appearance="Secondary" Margin="0,24,0,0"
                      Text="Richie — offline personal finance. Version 0.1 (in development)." />
    </StackPanel>
</Page>
